# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# --- Google Gemini via Vertex AI (scored requirement: Vertex, NOT AI Studio) ---
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=<YOUR_GCP_PROJECT_ID>
GOOGLE_CLOUD_LOCATION=us-central1
# Locked by scripts/model_probe.py during Phase 0 (prefers a Gemini 3 model, falls back to 2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash
# Auth is via Application Default Credentials — run: gcloud auth application-default login
# (No GOOGLE_API_KEY on the Vertex path.)

# --- Phoenix Cloud (tracing + evals) ---
# Create the key at https://app.phoenix.arize.com (format: px_live_...). This is a PHOENIX key,
# NOT an Arize AX key — we are on Phoenix, not AX.
PHOENIX_API_KEY=
# Space Hostname from Phoenix → Settings. Include /s/<space> but DO NOT append /v1/traces —
# the SDK adds it. The bare host (https://app.phoenix.arize.com) will 401.
# Example: https://app.phoenix.arize.com/s/your-space
PHOENIX_COLLECTOR_ENDPOINT=
# Target agent's traces land in this project (the SRE reads/diagnoses it). Phase 1 uses this name.
PHOENIX_PROJECT_NAME=incident-agent
